# ÖBS Giriş Bilgileri - Selçuk Üniversitesi
# NOT: Bu değişken isimleri GitHub Secrets ile uyumludur
OBS_USER=your_student_number
OBS_PASS=your_password

# Telegram Bot Yapılandırması
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# JSONBin.io - Bulut depolama (GitHub Actions için gerekli)
JSONBIN_KEY=your_jsonbin_api_key
JSONBIN_ID=your_jsonbin_bin_id

# GitHub Actions için (Opsiyonel)
GITHUB_TOKEN=
GITHUB_REPO=
